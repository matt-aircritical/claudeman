{
  "name": "claudeman",
  "displayName": "ClaudeMan",
  "description": "Browse, search, and resume Claude Code sessions",
  "version": "0.2.0",
  "publisher": "claudeman",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [{
        "id": "claudeman",
        "title": "ClaudeMan",
        "icon": "media/icon.svg"
      }]
    },
    "views": {
      "claudeman": [{
        "id": "claudeman.sessions",
        "name": "Sessions",
        "type": "webview"
      }]
    },
    "commands": [
      { "command": "claudeman.resumeSession", "title": "Resume Session", "category": "ClaudeMan" },
      { "command": "claudeman.forkSession", "title": "Fork Session", "category": "ClaudeMan" },
      { "command": "claudeman.forkFromExchange", "title": "Fork from Exchange", "category": "ClaudeMan" },
      { "command": "claudeman.refreshSessions", "title": "Refresh Sessions", "category": "ClaudeMan", "icon": "$(refresh)" },
      { "command": "claudeman.viewAll", "title": "View: All Sessions", "category": "ClaudeMan", "icon": "$(list-flat)" },
      { "command": "claudeman.viewByProject", "title": "View: By Project", "category": "ClaudeMan", "icon": "$(folder)" },
      { "command": "claudeman.viewRecent", "title": "View: Recent", "category": "ClaudeMan", "icon": "$(history)" },
      { "command": "claudeman.searchSessions", "title": "Search Sessions", "category": "ClaudeMan", "icon": "$(search)" },
      { "command": "claudeman.clearSearch", "title": "Clear Search", "category": "ClaudeMan", "icon": "$(close)" }
    ],
    "menus": {
      "view/title": [
        { "command": "claudeman.refreshSessions", "when": "view == claudeman.sessions", "group": "navigation@1" }
      ]
    },
    "configuration": {
      "title": "ClaudeMan",
      "properties": {
        "claudeman.claudeCommand": { "type": "string", "default": "claude", "description": "Path to the claude binary" },
        "claudeman.claudeArgs": { "type": "array", "items": { "type": "string" }, "default": [], "description": "Extra arguments appended when resuming sessions" },
        "claudeman.sessionDirectory": { "type": "string", "default": "", "description": "Path to .claude directory (auto-detected if empty)" },
        "claudeman.defaultView": { "type": "string", "enum": ["all", "projects", "recent"], "default": "all", "description": "Default view mode on startup" },
        "claudeman.previewOnClick": { "type": "boolean", "default": true, "description": "Auto-open preview when clicking a session" }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "test": "node --import tsx --test test/*.test.ts",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.0.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "smol-toml": "^1.3.0"
  }
}
